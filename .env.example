# CoinGecko Demo API key (free).
# Create one at https://www.coingecko.com/en/developers/dashboard
# Then copy this file to .env.local and paste your key below.
COINGECKO_API_KEY=

# Supabase project credentials (Project Settings → API).
# The publishable/anon key is public and safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
