# Copy this file to .env.local and fill in the values you need.
#
# The first block is everything required to boot the app. The blocks after it
# are per-feature: without them the app still runs, but the feature they name
# fails at the moment you reach for it.
#
# NOTE ON `vercel env pull`: it pulls the *development* target by default, and
# it writes the literal `[SENSITIVE]` for any variable marked Sensitive in
# Vercel (those are write-only and cannot be read back — not by the CLI, not by
# the dashboard). So a pull can silently leave you with placeholders instead of
# values, and `--environment=production` will not fix that. If a variable here
# is missing locally, add it to the Development target or paste it in by hand.

# ─── Required to run the app ──────────────────────────────────────────────

# CoinGecko Demo API key (free) — every market, coin, chart and price route.
# Create one at https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=

# Supabase project credentials (Project Settings → API).
# The publishable/anon key is public and safe to expose to the browser.
# Without these the app proxy fails on every request ("Invalid supabaseUrl").
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Bybit spot sync (Portfolio → Data → "Sync from Bybit") ───────────────

# Read-only API key: the sync only ever READS executions and only ever INSERTs
# into your ledger. Create it at
# https://www.bybit.com/app/user/api-management — grant read permission only.
# Server-side only; these must never reach the client bundle.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── Trading sleeve daily cron (/api/sleeve/run) ──────────────────────────

# Service-role key (Project Settings → API). BYPASSES ROW-LEVEL SECURITY —
# the cron has no user session, so it cannot use an RLS-scoped client. Never
# import lib/supabase/service.ts from client code, and treat this key as
# highly sensitive wherever it lands.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the cron route checks as `Authorization: Bearer $CRON_SECRET`.
# Vercel Cron sends it automatically in production. Generate any long random
# string, e.g. `openssl rand -hex 32` — do not leave a guessable value here.
CRON_SECRET=

# Supabase auth user id (UUID) that owns the sleeve rows the cron writes.
SLEEVE_OWNER_USER_ID=

# ─── Optional ─────────────────────────────────────────────────────────────

# Absolute origin used to build OG image URLs for shared links.
# Defaults to http://localhost:3000 when unset (app/layout.tsx).
NEXT_PUBLIC_SITE_URL=
